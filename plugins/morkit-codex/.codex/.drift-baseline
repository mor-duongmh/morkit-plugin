#   brainstorming/SKILL.md:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
#   writing-plans/SKILL.md:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
#
# Lines starting with '#' and blank lines are ignored. Do not edit by hand —
# always run the sync script so the hash matches the on-disk content.
